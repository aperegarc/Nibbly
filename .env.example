# Copia a `.env` para Expo (solo EXPO_PUBLIC_* llegan al cliente).

EXPO_PUBLIC_SUPABASE_URL=https://TU_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=TU_CLAVE_ANON

# Solo para scripts locales (p. ej. npm run recipes:import). No uses esto en la app.
SUPABASE_URL=https://TU_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_SECRETA

